# Application Configuration
APP_NAME="SACCO Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend URLs (for password reset emails)
ADMIN_APP_URL=http://localhost:5173
CLIENT_PORTAL_URL=http://localhost:5174

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sacco_db
DB_USERNAME=root
DB_PASSWORD=

# Cache Configuration
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis Configuration (optional, for production)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Laravel Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174

# CORS Configuration
CORS_ALLOWED_ORIGINS=*

# Mail Configuration
MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@sacco.local"
MAIL_FROM_NAME="${APP_NAME}"

# SMS Configuration
SMS_ENABLED=false
SMS_PROVIDER=africastalking
SMS_API_KEY=
SMS_USERNAME=
SMS_SENDER_ID=SACCO

# SACCO Configuration
SACCO_LOAN_MULTIPLIER=3
SACCO_MIN_GUARANTORS=2
SACCO_INTEREST_RATE=12
SACCO_CURRENCY=UGX
